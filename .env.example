# Firebase config — copy this file to `.env` and fill in real values.
# Find them in google-services.json (Firebase Console → Project Settings →
# Your apps → Android app → download google-services.json), mapped as:
#   api_key.current_key        -> EXPO_PUBLIC_FIREBASE_API_KEY
#   project_id                 -> EXPO_PUBLIC_FIREBASE_PROJECT_ID (also authDomain/storageBucket)
#   project_number             -> EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
#   mobilesdk_app_id           -> EXPO_PUBLIC_FIREBASE_APP_ID
#   storage_bucket             -> EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET
#
# These EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.
# Note: Firebase web/client API keys are NOT secret — they ship in the app
# regardless. Real protection comes from Firebase Security Rules.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Named Firestore database ID. Leave blank to use the "(default)" database.
EXPO_PUBLIC_FIREBASE_DATABASE_ID=
# Only needed if Realtime Database is enabled:
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
